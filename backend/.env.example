# 服务器端口设置
PORT=3000

# 数据库连接配置
DB_HOST=mysql          # 数据库主机地址（Docker部署时使用mysql，本地部署使用localhost或127.0.0.1）
DB_PORT=3306           # 数据库端口
DB_NAME=campus_flower  # 数据库名称
DB_USER=root           # 数据库用户名
DB_PASSWORD=password123 # 数据库密码

# Redis缓存配置
REDIS_HOST=redis       # Redis主机地址（Docker部署时使用redis，本地部署使用localhost或127.0.0.1）
REDIS_PORT=6379        # Redis端口
REDIS_PASSWORD=        # Redis密码（如果没有密码则留空）
REDIS_DB=0             # Redis数据库索引（从0开始）

# 微信小程序配置
WX_APPID=wx1234567890abcdef     # 微信小程序AppID，需要从微信公众平台获取
WX_SECRET=xxxxxxxxxxxxxxxx     # 微信小程序AppSecret，需要从微信公众平台获取

# 腾讯云COS配置
COS_SECRET_ID=AKIDxxxxxxx      # 腾讯云API密钥ID，从腾讯云控制台获取
COS_SECRET_KEY=xxxxxxx         # 腾讯云API密钥Key，从腾讯云控制台获取
COS_BUCKET=flower-1234567890   # 腾讯云COS存储桶名称
COS_REGION=ap-guangzhou        # 腾讯云COS存储桶地域，如ap-guangzhou（广州）、ap-beijing（北京）等

# JWT配置
JWT_SECRET=campus-flower-secret-key-2026  # JWT签名密钥，用于生成和验证Token，建议使用随机字符串
